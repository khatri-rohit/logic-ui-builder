{
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "sourcegraph@claude-plugins-official": true,
    "supabase@claude-plugins-official": true
  },
  "defaultMode": "bypassPermissions",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'echo \"{\\\"systemMessage\\\": \\\"Code updated. Run /claude-md-management:revise-claude-md to capture learnings in CLAUDE.md.\\\"}\"'",
            "async": true,
            "statusMessage": "Checking CLAUDE.md maintenance..."
          }
        ]
      }
    ]
  }
}
